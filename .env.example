# ── Exchange ──────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
TRADE_SYMBOL=BTCUSDT

# ── Paper trading (set to false when ready to go live) ────────
PAPER_TRADE=true

# ── Risk settings ─────────────────────────────────────────────
MAX_RISK_PCT=2         # % of balance risked per trade
MAX_POSITION=100       # max USD per trade
DAILY_LOSS_PCT=3       # stop bot if down this % in a day

# ── MongoDB (reuse your existing Atlas cluster) ───────────────
MONGODB_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/trading

# ── Notifications ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+1your_twilio_number
ALERT_PHONE=+1your_personal_number

# ── AI / OpenClaw ─────────────────────────────────────────────
OPENCLAW_URL=http://127.0.0.1:18789
ANTHROPIC_API_KEY=already_set_in_railway

# ── X API (optional — bot works without it) ───────────────────
X_BEARER_TOKEN=your_x_bearer_token
